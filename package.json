{
  "name": "kilo-code-model-selector",
  "displayName": "Kilo Code Model Selector",
  "description": "Extension để chọn model cho Kilo Code",
  "version": "1.1.0",
  "repository": "https://github.com/example/kilo-code-model-selector",
  "publisher": "custom",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "build": "vsce package"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kilo-code-model-selector.getFreeModels",
        "title": "Kilo Code: Get Free Models"
      },
      {
        "command": "kilo-code-model-selector.selectModel",
        "title": "Kilo Code: Select Model"
      },
      {
        "command": "kilo-code-model-selector.showCurrentModel",
        "title": "Kilo Code: Show Current Model"
      }
    ],
    "configuration": {
      "title": "Kilo Code Model Selector",
      "properties": {
        "kilo-code.vsCodeLmModelSelector.current_mode": {
          "type": "object",
          "default": {},
          "description": "Current selected model mode"
        },
        "kilo-code.vsCodeLmModelSelector.qwen-coder-32b": {
          "type": "object",
          "default": {},
          "description": "Qwen3 Coder 32B configuration"
        },
        "kilo-code.vsCodeLmModelSelector.qwen-coder-8b": {
          "type": "object",
          "default": {},
          "description": "Qwen3 Coder 8B configuration"
        },
        "kilo-code.vsCodeLmModelSelector.glm-air": {
          "type": "object",
          "default": {},
          "description": "GLM 4.5 Air configuration"
        },
        "kilo-code.vsCodeLmModelSelector.glm-flash": {
          "type": "object",
          "default": {},
          "description": "GLM 4 Flash configuration"
        },
        "kilo-code.vsCodeLmModelSelector.deepseek-r1": {
          "type": "object",
          "default": {},
          "description": "DeepSeek R1 configuration"
        },
        "kilo-code.vsCodeLmModelSelector.deepseek-v3": {
          "type": "object",
          "default": {},
          "description": "DeepSeek V3 configuration"
        },
        "kilo-code.vsCodeLmModelSelector.kimi-k2": {
          "type": "object",
          "default": {},
          "description": "Kimi K2 configuration"
        },
        "kilo-code.vsCodeLmModelSelector.kimi-k1.5": {
          "type": "object",
          "default": {},
          "description": "Kimi K1.5 configuration"
        },
        "kilo-code.vsCodeLmModelSelector.mistral-nemo": {
          "type": "object",
          "default": {},
          "description": "Mistral Nemo configuration"
        },
        "kilo-code.vsCodeLmModelSelector.codellama-70b": {
          "type": "object",
          "default": {},
          "description": "CodeLlama 70B configuration"
        },
        "kilo-code.vsCodeLmModelSelector.starcoder2-15b": {
          "type": "object",
          "default": {},
          "description": "StarCoder2 15B configuration"
        }
      }
    }
  },
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js"
}
