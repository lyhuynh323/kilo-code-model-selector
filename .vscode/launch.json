{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=d:/Github/VSCode_Project/kilo-code-model-selector",
                "--new-window",
                "--disable-gpu"
            ],
            "stopOnEntry": false,
            "presentation": {
                "hidden": false,
                "group": "aca",
                "order": 1
            }
        }
    ]
}